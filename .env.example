# Environment Configuration
# Copy this file to .env and fill in your values

# LLM Stats API Key (get from https://llm-stats.com/settings?tab=api-keys)
LLM_STATS_API_KEY=your_api_key_here

# Database
DB_NAME=llm
DB_USER=admin
DB_PASS=change_me_in_production

# Airflow
AIRFLOW_USER=admin
AIRFLOW_PASS=change_me_in_production
